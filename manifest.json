{
  "manifest_version": 3,
  "name": "JumpAround",
  "description": "Rediscover the weird web — recommend pages, jump to something new.",
  "version": "0.1.0",

  "action": {
    "default_popup": "popup.html",
    "default_title": "JumpAround"
  },

  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },

  "permissions": ["storage", "activeTab"]
}
