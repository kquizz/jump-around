{
  "manifest_version": 3,
  "name": "JumpAround",
  "description": "Rediscover the weird web — recommend pages, jump to something new.",
  "version": "0.2.0",

  "action": {
    "default_popup": "popup.html",
    "default_title": "JumpAround"
  },

  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },

  "permissions": ["storage", "activeTab"],

  "host_permissions": [
    "https://jumparound.kquizz.com/*",
    "http://localhost:3000/*"
  ]
}
